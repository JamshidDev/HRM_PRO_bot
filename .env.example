# ─── HRM Telegram Bot — env namuna ───
# Nusxa oling: cp .env.example .env.local (yoki .env.development / .env.production)
# 3 rejim: .env.local (lokal), .env.development (dev), .env.production (prod).
# Ishga tushirish: npm run local | npm run dev | npm run prod

# Telegram bot tokeni (@BotFather). Local/dev va PROD uchun ALOHIDA token.
# Backend'ga Bot-Token header sifatida ham shu yuboriladi —
# backend .env dagi TELEGRAM_BOT_TOKEN bilan bir xil bo'lishi shart.
BOT_TOKEN=

# HRM backend API bazasi:
#   local → http://localhost:8001
#   dev   → https://dev-hrm-api.das-uty.uz
#   prod  → https://hrm-api.railway.uz
SERVICE_URL=

# Xatolik xabarnomalari yuboriladigan telegram chat_id
NOTIFICATION_ID=
